    "@langchain/mongodb": "^1.1.0",
    "@langchain/textsplitters": "^1.0.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "groq-sdk": "^0.7.0",
    "langchain": "^1.2.30",
    "lucide-react": "^0.577.0",
    "mongodb": "^7.1.0",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.13.1",
    "remark-gfm": "^4.0.0",
    "swr": "^2.4.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
